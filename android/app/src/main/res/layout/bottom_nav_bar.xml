<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="106dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="#26000000"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/navDevicesTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/navDevicesIndicator"
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:layout_marginBottom="8dp"
                android:background="@color/dash_emerald_bright"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/navDevicesIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_devices"
                android:contentDescription="@string/nav_devices" />

            <TextView
                android:id="@+id/navDevicesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_devices"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotificationsTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <Space
                android:layout_width="28dp"
                android:layout_height="27dp" />

            <TextView
                android:id="@+id/navNotificationsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_notifications"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettingsTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <View
                android:id="@+id/navSettingsIndicator"
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:layout_marginBottom="8dp"
                android:background="@color/dash_emerald_bright"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/navSettingsIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="@string/nav_settings" />

            <TextView
                android:id="@+id/navSettingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_settings"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/navNotificationsCircle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_nav_center_button"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/navNotificationsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bell"
            android:contentDescription="@string/nav_notifications" />

    </FrameLayout>

</FrameLayout>
